{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "4SeletPay",
  "colors": {
    "primary": "#007AFF",
    "light": "#0A84FF",
    "dark": "#0056B3"
  },
  "appearance": {
