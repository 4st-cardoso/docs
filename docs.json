              {
                "group": "Introdução",
                "pages": [
                  "pages/start/introduction"
                ]
              }
            ]
          },
          {
            "tab": "Documentação",
            "groups": [
              {
                "group": "Autenticação",
                "pages": [
                  "pages/autenticacao/reference",
                  "pages/autenticacao/login",
                  "pages/autenticacao/new-user"
                ]
              },
              {
                "group": "Cobranças",
                "pages": [
                  "pages/cobrancas/reference",
                  "pages/cobrancas/create",
                  "pages/cobrancas/list",
                  "pages/cobrancas/get",
                  "pages/cobrancas/cancel",
                  "pages/cobrancas/refund"
                ]
              },
              {
                "group": "Pedidos",
                "pages": [
                  "pages/pedidos/reference",
                  "pages/pedidos/confirmations",
                  "pages/pedidos/verify",
                  "pages/pedidos/resend"
                ]
              },
              {
                "group": "Assinaturas",
                "pages": [
                  "pages/assinaturas/reference",
                  "pages/assinaturas/create",
                  "pages/assinaturas/cancel",
                  "pages/assinaturas/change-card",
                  "pages/assinaturas/change-payment-method",
                  "pages/assinaturas/invoices",
                  "pages/assinaturas/items",
                  "pages/assinaturas/update-item"
