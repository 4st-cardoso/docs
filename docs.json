              {
                "group": "Faturas",
                "pages": [
                  "pages/faturas/reference",
                  "pages/faturas/pay-overdue"
                ]
              }
            ]
          }
        ]
      },
      {
        "version": "v2",
        "tag": "Em breve",
        "tabs": [
          {
            "tab": "API v2",
            "pages": [
              "pages/v2/coming-soon"
            ]
          }
        ]
      }
